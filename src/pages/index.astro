---
import BaseLayout from "../layouts/BaseLayout.astro";

const yoyoVideos = [
  { id: "5YnG1TBW0VM", title: "Yoyo's Code Club — Deploy Your Node [v1.7]" },
  { id: "4fTAYphJg3Y", title: "Yoyo's Code Club — AutoComplete Searchbar [v1.6]" },
  { id: "LHS26WYENR0", title: "Yoyo's Code Club — Virtual Assistant! Debunking AI [v1.5]" },
  { id: "WGY2Jo5z8nI", title: "Yoyo's Code Club — Let's talk socket.io! [v1.4]" },
  { id: "CxwhXPwzuvE", title: "Yoyo's Code Show — Let's talk privacy! [v1.3]" },
  { id: "kE3i6k4IteA", title: "Yoyo's Code Show — Let's Bootstrap! [v1.2]" },
  { id: "PsitAWQ7iw8", title: "Yoyo's Code Show — Let's Django! [v1.1]" },
];
---
<BaseLayout title="Home">
  <section class="hero">
    <p class="eyebrow">Engineer · Teacher</p>
    <h1>Youssef Sawiris</h1>
    <p class="lede">
      I build software and I teach 6th grade math. Previously an engineer at Strava;
      now in the classroom at Lodestar (East Oakland) while shipping side projects
      that sit between code and education — with a soft spot for getting more kids into CS.
    </p>
    <div class="actions">
      <a class="btn primary" href="/resume/Youssef_Sawiris_Resume_SMASH_polished.pdf" data-astro-reload>Resume (PDF)</a>
      <a class="btn" href="mailto:sawirisyoussef@gmail.com">Email me</a>
      <a class="btn" href="https://github.com/ysawiris">GitHub</a>
      <a class="btn" href="https://www.linkedin.com/in/youssef-sawiris/">LinkedIn</a>
    </div>
  </section>

  <div class="tracks">
    <a class="track eng" href="/engineering/">
      <h3>Engineering →</h3>
      <p>Side projects, agents, and tools I've built. Mostly TypeScript, Python, and React.</p>
    </a>
    <a class="track edu" href="/teaching/">
      <h3>Teaching →</h3>
      <p>Classroom culture, lesson design, and reflections from my first year of teaching math.</p>
    </a>
  </div>

  <div class="section-header">
    <h2>Selected work</h2>
    <a href="/engineering/">All projects →</a>
  </div>

  <div class="cards">
    <div class="card">
      <h3><a href="https://2cm.ai">2cm.ai</a></h3>
      <div class="meta">Next.js · PostgreSQL · SaaS</div>
      <a class="demo-link" href="https://2cm.ai">Visit the site →</a>
      <p>Multi-tenant SaaS for countertop fabrication businesses — canvas-based design tools, configurable pricing engine, customer quote portals, Stripe billing.</p>
      <div class="tags">
        <span class="tag eng">saas</span>
        <span class="tag eng">next.js</span>
      </div>
    </div>

    <div class="card">
      <a class="card-preview" href="https://ysawiris.github.io/satellite-tracker/" data-astro-reload aria-hidden="true" tabindex="-1">
        <img src="/previews/satellite-tracker.jpg" alt="" width="1100" height="618" loading="lazy" />
      </a>
      <h3><a href="https://ysawiris.github.io/satellite-tracker/" data-astro-reload>satellite-tracker</a></h3>
      <div class="meta">JavaScript · CesiumJS</div>
      <a class="demo-link" href="https://ysawiris.github.io/satellite-tracker/" data-astro-reload>Try the live demo →</a>
      <p>Real-time tracker for every visible satellite over Earth — 2D map with day/night terminator, 3D globe with NASA cloud-cover composites, observer-centered sky radar, and onboard ride-along camera.</p>
      <div class="tags">
        <span class="tag eng">javascript</span>
        <span class="tag eng">visualization</span>
      </div>
    </div>

    <div class="card">
      <a class="card-preview" href="/lyric-generator/" data-astro-reload aria-hidden="true" tabindex="-1">
        <img src="/previews/lyric-generator.jpg" alt="" width="568" height="416" loading="lazy" />
      </a>
      <h3><a href="/lyric-generator/" data-astro-reload>lyric-generator</a></h3>
      <div class="meta">JavaScript · Markov + rhyme schemes</div>
      <a class="demo-link" href="/lyric-generator/" data-astro-reload>Try the live demo →</a>
      <p>Generate song lyrics by artist style. Picks artists, themes, Markov order, and rhyme schemes (AABB, ABAB, ABBA, free verse). Pure client-side — runs entirely in your browser.</p>
      <div class="tags">
        <span class="tag eng">javascript</span>
        <span class="tag eng">creative</span>
      </div>
    </div>

    <div class="card">
      <h3>ai-teacher</h3>
      <div class="meta">Next.js · LLM</div>
      <p>Dashboard for visualizing student growth across attendance, grades, state testing, and discipline — with an AI assistant that answers questions about individual students or classes in plain language.</p>
      <div class="tags">
        <span class="tag eng">llm</span>
        <span class="tag edu">education</span>
      </div>
    </div>

    <div class="card">
      <h3>flowagent</h3>
      <div class="meta">Next.js · AI agents</div>
      <p>Workflow automation for Instagram, WhatsApp, Gmail, and Calendar with text + voice AI agents. Visual builder on React Flow, Inngest queue, OpenAI + Anthropic runtimes.</p>
      <div class="tags">
        <span class="tag eng">agents</span>
        <span class="tag eng">next.js</span>
      </div>
    </div>

    <div class="card">
      <h3><a href="#yoyo-code-club">YoYo Code Club</a></h3>
      <div class="meta">YouTube · 2020–2021</div>
      <a class="demo-link" href="#yoyo-code-club">Watch the episodes ↓</a>
      <p>Seven beginner Python + JavaScript video lessons I produced as a senior CS undergrad: Django, Bootstrap, socket.io, a virtual assistant, autocomplete search, Node deployment, online privacy.</p>
      <div class="tags">
        <span class="tag edu">teaching</span>
        <span class="tag eng">video</span>
      </div>
    </div>
  </div>

  <div class="section-header" id="yoyo-code-club">
    <h2>Watch — YoYo Code Club</h2>
    <a href="https://www.youtube.com/@learn-with-yoyo">On YouTube →</a>
  </div>
  <p style="color: var(--text-muted); margin-top: 0.5rem;">
    Beginner Python and JavaScript lessons I made during my senior year of CS undergrad
    (@learn-with-yoyo). Seven episodes.
  </p>

  <section class="video-carousel" aria-label="YoYo Code Club episodes">
    <div class="video-stage">
      <iframe
        id="yoyo-iframe"
        src={`https://www.youtube-nocookie.com/embed/${yoyoVideos[0].id}`}
        title={yoyoVideos[0].title}
        allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>
    <div class="video-controls">
      <button type="button" id="yoyo-prev" aria-label="Previous episode">←</button>
      <div class="video-caption">
        <span class="video-title" id="yoyo-title">{yoyoVideos[0].title}</span>
        <span class="video-counter"><span id="yoyo-pos">1</span> / {yoyoVideos.length}</span>
      </div>
      <button type="button" id="yoyo-next" aria-label="Next episode">→</button>
    </div>
    <div class="video-dots" id="yoyo-dots">
      {yoyoVideos.map((v, i) => (
        <button
          type="button"
          data-index={i}
          aria-label={`Episode ${i + 1}`}
          aria-current={i === 0 ? "true" : "false"}
        ></button>
      ))}
    </div>
  </section>

  <script is:inline define:vars={{ yoyoVideos }}>
    function initYoyoCarousel() {
      const root = document.querySelector(".video-carousel");
      if (!root || root.dataset.yoyoBound === "1") return;
      const iframe = document.getElementById("yoyo-iframe");
      const title = document.getElementById("yoyo-title");
      const pos = document.getElementById("yoyo-pos");
      const prev = document.getElementById("yoyo-prev");
      const next = document.getElementById("yoyo-next");
      const dotsEl = document.getElementById("yoyo-dots");
      if (!iframe || !title || !pos || !prev || !next || !dotsEl) return;
      root.dataset.yoyoBound = "1";
      const dots = Array.from(dotsEl.querySelectorAll("button"));
      let i = 0;

      function show(n) {
        i = (n + yoyoVideos.length) % yoyoVideos.length;
        const v = yoyoVideos[i];
        iframe.src = "https://www.youtube-nocookie.com/embed/" + v.id;
        iframe.title = v.title;
        title.textContent = v.title;
        pos.textContent = String(i + 1);
        dots.forEach((d, idx) => d.setAttribute("aria-current", idx === i ? "true" : "false"));
      }

      prev.addEventListener("click", () => show(i - 1));
      next.addEventListener("click", () => show(i + 1));
      dots.forEach((d) =>
        d.addEventListener("click", () => show(Number(d.dataset.index)))
      );
    }

    initYoyoCarousel();
    document.addEventListener("astro:page-load", initYoyoCarousel);
  </script>

  <div class="section-header">
    <h2>From the classroom</h2>
    <a href="/teaching/">All teaching →</a>
  </div>

  <div class="cards">
    <div class="card">
      <h3>Classroom Culture &amp; Community</h3>
      <div class="meta">Spring 2026 · CFA</div>
      <p>How I'm building a math classroom where students feel known, safe, and capable.</p>
      <div class="tags">
        <span class="tag edu">culture</span>
        <span class="tag edu">reflection</span>
      </div>
    </div>

    <div class="card">
      <h3>Heritage Tree</h3>
      <div class="meta">Identity activity · Nov 2025</div>
      <p>A class activity rooting math identity in family, language, and place.</p>
      <div class="tags">
        <span class="tag edu">identity</span>
        <span class="tag edu">activity</span>
      </div>
    </div>

    <div class="card">
      <h3>Lesson Tuning</h3>
      <div class="meta">Lesson design · 2026</div>
      <p>Graphic organizer I use to revise lessons after teaching them — what to cut, what to amplify.</p>
      <div class="tags">
        <span class="tag edu">planning</span>
        <span class="tag edu">reflection</span>
      </div>
    </div>
  </div>
</BaseLayout>
