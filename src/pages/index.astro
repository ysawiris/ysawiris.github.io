---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Home">
  <section class="hero">
    <p class="eyebrow">Engineer · Teacher</p>
    <h1>Youssef Sawiris</h1>
    <p class="lede">
      I build software and I teach 6th grade math. Previously an engineer at Strava;
      now in the classroom at Lodestar (East Oakland) while shipping side projects
      that sit between code and education — with a soft spot for getting more kids into CS.
    </p>
    <div class="actions">
      <a class="btn primary" href="/resume/Youssef_Sawiris_Resume_SMASH_polished.pdf">Resume (PDF)</a>
      <a class="btn" href="mailto:sawirisyoussef@gmail.com">Email me</a>
      <a class="btn" href="https://github.com/ysawiris">GitHub</a>
      <a class="btn" href="https://www.linkedin.com/in/youssef-sawiris/">LinkedIn</a>
    </div>
  </section>

  <div class="tracks">
    <a class="track eng" href="/engineering/">
      <h3>Engineering →</h3>
      <p>Side projects, agents, and tools I've built. Mostly TypeScript, Python, and React.</p>
    </a>
    <a class="track edu" href="/teaching/">
      <h3>Teaching →</h3>
      <p>Classroom culture, lesson design, and reflections from my first year of teaching math.</p>
    </a>
  </div>

  <div class="section-header">
    <h2>Selected work</h2>
    <a href="/engineering/">All projects →</a>
  </div>

  <div class="cards">
    <div class="card">
      <h3><a href="https://2cm.ai">2cm.ai</a></h3>
      <div class="meta">Next.js · PostgreSQL · SaaS</div>
      <p>Multi-tenant SaaS for countertop fabrication businesses — canvas-based design tools, configurable pricing engine, customer quote portals, Stripe billing.</p>
      <div class="tags">
        <span class="tag eng">saas</span>
        <span class="tag eng">next.js</span>
      </div>
    </div>

    <div class="card">
      <h3>ai-teacher</h3>
      <div class="meta">Next.js · LLM</div>
      <p>Dashboard for visualizing student growth across attendance, grades, state testing, and discipline — with an AI assistant that answers questions about individual students or classes in plain language.</p>
      <div class="tags">
        <span class="tag eng">llm</span>
        <span class="tag edu">education</span>
      </div>
    </div>

    <div class="card">
      <h3>flowagent</h3>
      <div class="meta">Next.js · AI agents</div>
      <p>Workflow automation for Instagram, WhatsApp, Gmail, and Calendar with text + voice AI agents. Visual builder on React Flow, Inngest queue, OpenAI + Anthropic runtimes.</p>
      <div class="tags">
        <span class="tag eng">agents</span>
        <span class="tag eng">next.js</span>
      </div>
    </div>

    <div class="card">
      <h3><a href="https://www.youtube.com/playlist?list=PLZ_SI6zSFXvCFiWtGFy4U3X3f1dAj9zGz">YoYo Code Club</a></h3>
      <div class="meta">YouTube · 2020–2021</div>
      <p>Seven beginner Python + JavaScript video lessons I produced as senior-year CS undergrad: Django, Bootstrap, socket.io, a virtual assistant, autocomplete search, Node deployment, and online privacy.</p>
      <div class="tags">
        <span class="tag edu">teaching</span>
        <span class="tag eng">video</span>
      </div>
    </div>
  </div>

  <div class="section-header">
    <h2>From the classroom</h2>
    <a href="/teaching/">All teaching →</a>
  </div>

  <div class="cards">
    <div class="card">
      <h3>Classroom Culture &amp; Community</h3>
      <div class="meta">Spring 2026 · CFA</div>
      <p>How I'm building a math classroom where students feel known, safe, and capable.</p>
      <div class="tags">
        <span class="tag edu">culture</span>
        <span class="tag edu">reflection</span>
      </div>
    </div>

    <div class="card">
      <h3>Heritage Tree</h3>
      <div class="meta">Identity activity · Nov 2025</div>
      <p>A class activity rooting math identity in family, language, and place.</p>
      <div class="tags">
        <span class="tag edu">identity</span>
        <span class="tag edu">activity</span>
      </div>
    </div>

    <div class="card">
      <h3>Lesson Tuning</h3>
      <div class="meta">Lesson design · 2026</div>
      <p>Graphic organizer I use to revise lessons after teaching them — what to cut, what to amplify.</p>
      <div class="tags">
        <span class="tag edu">planning</span>
        <span class="tag edu">reflection</span>
      </div>
    </div>
  </div>
</BaseLayout>
