---
import BaseLayout from "../layouts/BaseLayout.astro";

interface Project {
  name: string;
  url?: string;
  meta: string;
  description: string;
  tags: string[];
}

const featured: Project[] = [
  {
    name: "2cm",
    url: "https://2cm.ai",
    meta: "Next.js · PostgreSQL · SaaS",
    description:
      "Multi-tenant SaaS for countertop fabrication businesses. Canvas-based design tools, configurable pricing engine, customer quote portals, Stripe billing, voice/AI integration. Built with a small team.",
    tags: ["saas", "next.js", "postgres", "stripe"],
  },
  {
    name: "flowagent",
    meta: "TypeScript · Workflow builder",
    description:
      "Visual workflow builder with a dashboard for managing customer-facing automations.",
    tags: ["agents", "react", "typescript"],
  },
  {
    name: "math-platform",
    meta: "Education · Web",
    description:
      "Tools and practice surfaces designed for 6th grade math instruction.",
    tags: ["education", "math", "web"],
  },
  {
    name: "ai-teacher",
    meta: "Python · LLM",
    description:
      "Experimental AI tutoring assistant that scaffolds math problems for students.",
    tags: ["llm", "education", "python"],
  },
  {
    name: "sf-permit-agent",
    meta: "Python · LLM agent",
    description:
      "Agent that helps navigate San Francisco's permit application process end-to-end.",
    tags: ["agents", "python", "civic"],
  },
  {
    name: "kordon",
    meta: "TypeScript",
    description: "In-development project.",
    tags: ["typescript"],
  },
  {
    name: "paper-trader",
    meta: "Trading simulator",
    description: "Paper trading sandbox for experimenting with strategies risk-free.",
    tags: ["finance", "tooling"],
  },
  {
    name: "local-news-agent",
    meta: "Python · Agent",
    description: "Agent that surfaces and summarizes local news.",
    tags: ["agents", "python"],
  },
  {
    name: "satellite-tracker",
    url: "https://github.com/ysawiris/satellite-tracker",
    meta: "Web · Visualization",
    description: "Real-time satellite tracking visualization.",
    tags: ["web", "visualization"],
  },
  {
    name: "queued-up",
    url: "https://github.com/ysawiris/queuedUp",
    meta: "React Native · iOS/Android",
    description: "Mobile app exploration that went through multiple iterations and platforms.",
    tags: ["mobile", "react-native"],
  },
];
---
<BaseLayout
  title="Engineering"
  description="Engineering projects by Youssef Sawiris — agents, web tools, and education software."
  wide={true}
>
  <section class="hero">
    <p class="eyebrow">Engineering</p>
    <h1>Things I've built</h1>
    <p class="lede">
      A working selection of side projects. Most are open source on
      <a href="https://github.com/ysawiris">GitHub</a>. Lately the focus has been LLM agents
      and tools that sit between code and education.
    </p>
  </section>

  <div class="cards">
    {featured.map((p) => (
      <div class="card">
        <h3>{p.url ? <a href={p.url}>{p.name}</a> : p.name}</h3>
        <div class="meta">{p.meta}</div>
        <p>{p.description}</p>
        <div class="tags">
          {p.tags.map((t) => <span class="tag eng">{t}</span>)}
        </div>
      </div>
    ))}
  </div>

  <p style="margin-top: 2.5rem; color: var(--text-muted); font-size: 0.95rem;">
    Some projects above are private or commercial work and aren't linked.
    Public repos live on <a href="https://github.com/ysawiris">GitHub</a>.
  </p>
</BaseLayout>
