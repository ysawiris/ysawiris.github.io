---
import BaseLayout from "../layouts/BaseLayout.astro";

interface Project {
  name: string;
  url?: string;
  repo?: string;
  meta: string;
  description: string;
  tags: string[];
  image?: { src: string; width: number; height: number };
}

const featured: Project[] = [
  {
    name: "2cm.ai",
    url: "https://2cm.ai",
    meta: "Next.js · PostgreSQL · SaaS",
    description:
      "Multi-tenant SaaS for countertop fabrication businesses. Canvas-based design tools, configurable pricing engine, customer quote portals, Stripe billing, voice/AI integration.",
    tags: ["saas", "next.js", "postgres", "stripe"],
    image: { src: "/previews/2cm.jpg", width: 1100, height: 687 },
  },
  {
    name: "flowagent",
    meta: "Next.js · AI agents",
    description:
      "Workflow automation across Instagram, WhatsApp, Gmail, and Google Calendar with configurable text and voice AI agents. Visual builder on React Flow, Inngest queue, OpenAI + Anthropic runtimes, Clerk auth, Postgres + Prisma.",
    tags: ["agents", "next.js", "typescript", "voice"],
  },
  {
    name: "ai-teacher",
    meta: "Next.js · LLM · Education",
    description:
      "Dashboard for visualizing student growth across attendance, grades, state testing, and discipline. Supports CSV/JSON uploads, multi-student comparison, and growth deltas across school years. An AI assistant can apply view changes (selected student, assessment lens, goals) from a natural-language prompt.",
    tags: ["llm", "education", "next.js"],
  },
  {
    name: "sf-permit-agent",
    meta: "Python · LLM agent",
    description:
      "Agent that navigates San Francisco's permit application process end-to-end — requirement lookup, contact discovery, neighbor petition generation, site-map generation, status tracking.",
    tags: ["agents", "python", "civic"],
  },
  {
    name: "voice_agent",
    meta: "Python · ElevenLabs · Bilingual",
    description:
      "Bilingual (English + Spanish) school-notification calling system. Outbound batch calls to parents from CSV, agent restricted to notification + teacher contact + meeting-request steps. Built for real classroom use.",
    tags: ["voice", "python", "education", "bilingual"],
  },
  {
    name: "kordon",
    meta: "Next.js · E-commerce",
    description:
      "Storefront for an aquarium and pond pet-products brand. Solo build.",
    tags: ["next.js", "ecommerce"],
  },
  {
    name: "math-platform",
    meta: "Education · Web",
    description:
      "Tools and practice surfaces designed for 6th grade math instruction.",
    tags: ["education", "math", "web"],
  },
];

const openSource: Project[] = [
  {
    name: "satellite-tracker",
    url: "https://ysawiris.github.io/satellite-tracker/",
    repo: "https://github.com/ysawiris/satellite-tracker",
    meta: "JS · CesiumJS · Live demo",
    description:
      "Web app that tracks every visible satellite over Earth — 2D map with day/night terminator, 3D globe with NASA cloud-cover composites, observer-centered sky radar with pass predictions, and an onboard ride-along camera. Pure static frontend; orbital math runs entirely in the browser.",
    tags: ["javascript", "visualization", "live-demo"],
    image: { src: "/previews/satellite-tracker.jpg", width: 1100, height: 618 },
  },
  {
    name: "lyric-generator",
    url: "/lyric-generator/",
    repo: "https://github.com/ysawiris/lyric-generator",
    meta: "JavaScript · Markov + rhyme schemes · Live demo",
    description:
      "Generate song lyrics by artist style. Pick artists, a theme, Markov order, and a rhyme scheme (AABB / ABAB / ABBA / free). Runs entirely in the browser; an optional server mode upgrades quality via Claude.",
    tags: ["javascript", "creative", "live-demo"],
    image: { src: "/previews/lyric-generator.jpg", width: 568, height: 416 },
  },
  {
    name: "queued-up",
    repo: "https://github.com/ysawiris/queuedUp",
    meta: "Node.js · Socket.IO · Spotify OAuth",
    description:
      "Add songs to your friends' Spotify queue in real time. Express + Socket.IO + MongoDB with Spotify OAuth.",
    tags: ["node", "websockets", "spotify"],
  },
];

const moreLocal: Project[] = [
  {
    name: "auto-fix-prs",
    meta: "Next.js · Postgres · pg-boss",
    description:
      "Internal dashboard for tracking engineering tasks and executing Codex/Claude runs that can commit, push, and open PRs.",
    tags: ["agents", "dx"],
  },
  {
    name: "instagram-dm-autoreply",
    meta: "Node.js · Meta webhooks",
    description:
      "HTTP webhook service that receives Instagram DM events from Meta and sends automatic text replies.",
    tags: ["node", "automation"],
  },
  {
    name: "ebay_manager",
    meta: "Python · eBay APIs",
    description:
      "Terminal-only CLI giving agents control over eBay listings, orders, refunds, messaging, notifications, and disputes.",
    tags: ["agents", "python", "cli"],
  },
  {
    name: "slides_creator_agent",
    meta: "Canva MCP · Markdown",
    description:
      "Generate slides from markdown and import them into Canva via the Canva MCP server.",
    tags: ["agents", "mcp"],
  },
  {
    name: "video_agent",
    meta: "ffmpeg · JSON schemas",
    description:
      "Starter toolkit for building brand promo videos with agent workflows — structured brief/script/shotlist inputs, schemas, prompt templates, and a placeholder renderer.",
    tags: ["agents", "video"],
  },
  {
    name: "local-news-agent",
    meta: "Python · Agent",
    description:
      "Agent that surfaces and summarizes local news.",
    tags: ["agents", "python"],
  },
  {
    name: "paper-trader",
    meta: "Python · yfinance",
    description:
      "Paper-trading sandbox using real Yahoo Finance data. 50/200-day SMA crossover strategy, bar-by-bar simulator with fees, equity curve and trade-log output. Immutable Portfolio dataclass — every fill returns a new copy.",
    tags: ["python", "finance"],
  },
  {
    name: "roblox_game",
    meta: "Roblox · Luau · Rojo",
    description:
      "\"Geo Lab Academy\" — a Rojo/Luau scaffold for a Roblox game project with auto-generated checkpoint markers for Chromebook-first playtests.",
    tags: ["luau", "roblox", "game"],
  },
  {
    name: "abraham-online-basketball-game",
    meta: "Node.js · Socket.IO",
    description:
      "Real-time browser 2v2 basketball game with server-authoritative gameplay. Shoot, pass, steal, block; bots fill empty slots; play-by-play feed.",
    tags: ["node", "websockets", "game"],
  },
];

const teaching: Project[] = [
  {
    name: "YoYo Code Club",
    url: "https://www.youtube.com/playlist?list=PLZ_SI6zSFXvCFiWtGFy4U3X3f1dAj9zGz",
    meta: "YouTube · 2020–2021 · YoYo Code Club",
    description:
      "Seven beginner Python and JavaScript video lessons I produced during senior year of CS undergrad: Let's Django, Let's Bootstrap, Let's talk privacy, Let's talk socket.io, Virtual Assistant / debunking AI, AutoComplete Searchbar, and Deploy Your Node.",
    tags: ["teaching", "video", "python", "javascript"],
  },
];
---
<BaseLayout
  title="Engineering"
  description="Engineering projects by Youssef Sawiris — agents, web tools, education software, and CS teaching videos."
  wide={true}
>
  <section class="hero">
    <p class="eyebrow">Engineering</p>
    <h1>Things I've built</h1>
    <p class="lede">
      A working selection. Most recent focus is LLM agents and tools that sit between code
      and education. Most projects live on <a href="https://github.com/ysawiris">GitHub</a>;
      some are private or commercial — happy to walk through them on request.
    </p>
  </section>

  <h2 style="margin-top: 2.5rem;">Featured</h2>
  <div class="cards">
    {featured.map((p) => (
      <div class="card">
        {p.image && p.url && (
          <a class="card-preview" href={p.url} data-astro-reload aria-hidden="true" tabindex="-1">
            <img src={p.image.src} alt="" width={p.image.width} height={p.image.height} loading="lazy" />
          </a>
        )}
        <h3>{p.url ? <a href={p.url}>{p.name}</a> : p.name}</h3>
        <div class="meta">{p.meta}</div>
        <p>{p.description}</p>
        <div class="tags">
          {p.tags.map((t) => <span class="tag eng">{t}</span>)}
        </div>
      </div>
    ))}
  </div>

  <h2 style="margin-top: 2.5rem;">Open source</h2>
  <div class="cards">
    {openSource.map((p) => (
      <div class="card">
        {p.image && p.url && (
          <a class="card-preview" href={p.url} data-astro-reload aria-hidden="true" tabindex="-1">
            <img src={p.image.src} alt="" width={p.image.width} height={p.image.height} loading="lazy" />
          </a>
        )}
        <h3>{p.url ? <a href={p.url} data-astro-reload>{p.name}</a> : p.name}</h3>
        <div class="meta">
          {p.meta}
          {p.repo && (
            <>
              {" · "}
              <a href={p.repo}>repo</a>
            </>
          )}
        </div>
        <p>{p.description}</p>
        <div class="tags">
          {p.tags.map((t) => <span class="tag eng">{t}</span>)}
        </div>
      </div>
    ))}
  </div>

  <h2 style="margin-top: 2.5rem;">CS teaching</h2>
  <div class="cards">
    {teaching.map((p) => (
      <div class="card">
        <h3>{p.url ? <a href={p.url}>{p.name}</a> : p.name}</h3>
        <div class="meta">{p.meta}</div>
        <p>{p.description}</p>
        <div class="tags">
          {p.tags.map((t) => <span class="tag edu">{t}</span>)}
        </div>
      </div>
    ))}
  </div>

  <h2 style="margin-top: 2.5rem;">More projects</h2>
  <div class="cards">
    {moreLocal.map((p) => (
      <div class="card">
        <h3>{p.url ? <a href={p.url}>{p.name}</a> : p.name}</h3>
        <div class="meta">{p.meta}</div>
        <p>{p.description}</p>
        <div class="tags">
          {p.tags.map((t) => <span class="tag eng">{t}</span>)}
        </div>
      </div>
    ))}
  </div>

  <p style="margin-top: 2.5rem; color: var(--text-muted); font-size: 0.95rem;">
    Older coursework and exploratory repos (data structures, CSS frameworks, blockchain tutorial,
    Spaceman game, Madlibs, etc.) live on <a href="https://github.com/ysawiris">GitHub</a>.
  </p>
</BaseLayout>
