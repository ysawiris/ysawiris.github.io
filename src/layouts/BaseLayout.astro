---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const {
  title,
  description = "Youssef Sawiris — engineer and math teacher. Portfolio of software work, classroom projects, and writing.",
  wide = false,
} = Astro.props;

const fullTitle = title === "Home" ? "Youssef Sawiris" : `${title} — Youssef Sawiris`;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://ysawiris.github.io${Astro.url.pathname}`} />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a href="/" class="brand">Youssef Sawiris</a>
        <div class="nav-links">
          <a href="/engineering/">Engineering</a>
          <a href="/teaching/">Teaching</a>
          <a href="/about/">About</a>
        </div>
      </nav>
    </header>
    <main class={wide ? "wide" : ""}>
      <slot />
    </main>
    <footer class="site-footer">
      <p>
        © 2026 Youssef Sawiris ·
        <a href="https://github.com/ysawiris">GitHub</a> ·
        <a href="mailto:sawirisyoussef@gmail.com">Email</a>
      </p>
    </footer>
  </body>
</html>
