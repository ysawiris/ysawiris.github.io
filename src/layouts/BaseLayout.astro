---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const {
  title,
  description = "Youssef Sawiris — engineer and math teacher. Portfolio of software work, classroom projects, and writing.",
  wide = false,
} = Astro.props;

const fullTitle = title === "Home" ? "Youssef Sawiris" : `${title} — Youssef Sawiris`;

const pathname = Astro.url.pathname;
const isActive = (href: string) => pathname === href || pathname.startsWith(href);
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://ysawiris.github.io${Astro.url.pathname}`} />
    <meta property="og:image" content="https://ysawiris.github.io/previews/og.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://ysawiris.github.io/previews/og.jpg" />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a href="/" class="brand">Youssef Sawiris</a>
        <div class="nav-links">
          <a href="/engineering/" aria-current={isActive("/engineering/") ? "page" : undefined}>Engineering</a>
          <a href="/teaching/" aria-current={isActive("/teaching/") ? "page" : undefined}>Teaching</a>
          <a href="/about/" aria-current={isActive("/about/") ? "page" : undefined}>About</a>
        </div>
      </nav>
    </header>
    <main class={wide ? "wide" : ""}>
      <slot />
    </main>
    <footer class="site-footer">
      <p>
        © 2026 Youssef Sawiris ·
        <a href="https://github.com/ysawiris">GitHub</a> ·
        <a href="https://www.linkedin.com/in/youssef-sawiris/">LinkedIn</a> ·
        <a href="https://www.youtube.com/playlist?list=PLZ_SI6zSFXvCFiWtGFy4U3X3f1dAj9zGz">YouTube</a> ·
        <a href="mailto:sawirisyoussef@gmail.com">Email</a>
      </p>
    </footer>
  </body>
</html>
